{
  "version": "0.1.2",
  "description": "Visual payload router for QR capture and automation",
  "homepage": "https://github.com/zunaidFarouque/VisioFlow-QR",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/zunaidFarouque/VisioFlow-QR/releases/download/v0.1.2/visioflow-win-x64.zip",
      "hash": "89ea66f24f4a61409d650629bf0070aa15f48c0314e65f9b56396191af6788b7",
      "extract_dir": "visioflow-win-x64"
    }
  },
  "bin": "visioflow.exe",
  "env_set": {
    "VISIOFLOW_MODELS_DIR": "$dir\\models"
  },
  "persist": "data",
  "post_install": [
    "$ErrorActionPreference = 'Stop'",
    "$persistRules = Join-Path $persist_dir 'rules.json'",
    "$appRulesDir = Join-Path $env:APPDATA 'visioflow'",
    "$appRules = Join-Path $appRulesDir 'rules.json'",
    "$defaultRules = Join-Path $dir 'default-rules.json'",
    "New-Item -ItemType Directory -Path $persist_dir -Force | Out-Null",
    "if (Test-Path $persistRules) { New-Item -ItemType Directory -Path $appRulesDir -Force | Out-Null; Copy-Item $persistRules $appRules -Force } elseif (Test-Path $appRules) { Copy-Item $appRules $persistRules -Force } elseif (Test-Path $defaultRules) { Copy-Item $defaultRules $persistRules -Force; New-Item -ItemType Directory -Path $appRulesDir -Force | Out-Null; Copy-Item $defaultRules $appRules -Force }",
    "& (Join-Path $dir 'install-shortcuts.ps1') -BinPath (Join-Path $dir 'visioflow.exe') -Force",
    "Write-Host 'VisioFlow bootstrap complete (shortcuts + rules).'"
  ],
  "pre_uninstall": [
    "$ErrorActionPreference = 'Stop'",
    "$appRules = Join-Path $env:APPDATA 'visioflow\\rules.json'",
    "$persistRules = Join-Path $persist_dir 'rules.json'",
    "if (Test-Path $appRules) { New-Item -ItemType Directory -Path $persist_dir -Force | Out-Null; Copy-Item $appRules $persistRules -Force }"
  ],
  "uninstaller": {
    "script": [
      "$ErrorActionPreference = 'Stop'",
      "$desktop = [Environment]::GetFolderPath('Desktop')",
      "$programs = [Environment]::GetFolderPath('Programs')",
      "$startMenu = Join-Path $programs 'VisioFlow'",
      "$names = @('VisioFlow Scan (Auto)', 'VisioFlow Scan (Copy)', 'VisioFlow Scan (Plain)', 'VisioFlow')",
      "foreach ($n in $names) { Remove-Item (Join-Path $desktop \"$n.lnk\") -Force -ErrorAction SilentlyContinue; Remove-Item (Join-Path $startMenu \"$n.lnk\") -Force -ErrorAction SilentlyContinue }",
      "$launcherRoot = Join-Path $env:APPDATA 'VisioFlow\\launchers'",
      "if (Test-Path $launcherRoot) { Remove-Item $launcherRoot -Recurse -Force -ErrorAction SilentlyContinue }",
      "if (Test-Path $startMenu) { if (-not (Get-ChildItem $startMenu -ErrorAction SilentlyContinue)) { Remove-Item $startMenu -Force -ErrorAction SilentlyContinue } }",
      "Write-Host 'Removed VisioFlow shortcuts and launchers. Rules kept in scoop persist (scoop uninstall -p to purge). visioflow: protocol registry left in HKCU (refreshed on next notify test).'"
    ]
  },
  "checkver": {
    "github": "https://github.com/zunaidFarouque/VisioFlow-QR"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/zunaidFarouque/VisioFlow-QR/releases/download/v$version/visioflow-win-x64.zip",
        "extract_dir": "visioflow-win-x64"
      }
    }
  }
}
